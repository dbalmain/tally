#!/usr/bin/env ruby
# frozen_string_literal: true

# pocketsmith-pull — fetch transactions from PocketSmith into Tally's import
# format.
#
# This tool is GENERIC and contains no account-specific data, so it is safe to
# check in / publish. All per-account state (folders, pull shims, logs) is
# created under exports/, which Tally keeps gitignored.
#
# Authentication: set POCKETSMITH_KEY to a PocketSmith developer key
# (Profile → Security & integrations → Manage developer keys).
#
# Usage:
#   tools/pocketsmith-pull sync          Discover accounts, create
#                                        exports/<Bank>/<Account>/ folders, and
#                                        drop a `pull` shim into each.
#   tools/pocketsmith-pull account <ID>  Emit Tally-import JSON for one
#                                        PocketSmith transaction-account id on
#                                        stdout. Run from the account folder;
#                                        reads/writes pull.log there for
#                                        incremental windowing. (This is what
#                                        the generated `pull` shim calls, and
#                                        what Tally runs during `cargo run`.)
#
# Categories: PocketSmith's category is parked in each transaction's metadata
# (pocketsmith_category) as an autocategorisation hint. It is deliberately NOT
# mapped onto Tally's own category system.

require 'net/http'
require 'json'
require 'uri'
require 'date'
require 'time'
require 'fileutils'

API_BASE = 'https://api.pocketsmith.com/v2'
# Re-fetch this many days before the previous pull's end date, so transactions
# that posted out of order get picked up. Re-pulled rows collide on the stable
# `ps-<id>` hash and are ignored by Tally's (account_id, hash) uniqueness.
OVERLAP_DAYS = 14

def api_key
  key = ENV['POCKETSMITH_KEY']
  if key.nil? || key.strip.empty?
    abort 'POCKETSMITH_KEY is not set (PocketSmith developer key required).'
  end
  key
end

# GET a URL, returning [parsed_body, http_response].
def api_get(url)
  uri = URI(url)
  req = Net::HTTP::Get.new(uri)
  req['X-Developer-Key'] = api_key
  req['Accept'] = 'application/json'

  res = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) { |http| http.request(req) }
  unless res.is_a?(Net::HTTPSuccess)
    abort "PocketSmith API #{res.code} for #{url}: #{res.body}"
  end

  [JSON.parse(res.body), res]
end

# Follow rel="next" Link headers, concatenating all pages of a list endpoint.
def api_get_all(url)
  items = []
  while url
    page, res = api_get(url)
    items.concat(page)
    url = next_link(res['link'])
  end
  items
end

def next_link(header)
  return nil if header.nil?

  header.split(',').each do |part|
    section = part.split(';').map(&:strip)
    next unless section.any? { |s| s == 'rel="next"' }

    return section[0][/\A<(.+)>\z/, 1]
  end
  nil
end

# Turn an arbitrary label into a filesystem-friendly folder name.
def folder_name(str)
  str.to_s.strip.gsub(/[^\w\-]+/, '-').gsub(/-+/, '-').gsub(/\A-|-\z/, '')
end

def fetch_accounts
  me, = api_get("#{API_BASE}/me")
  api_get_all("#{API_BASE}/users/#{me['id']}/accounts")
end

# Build [bank_folder, account_folder, txn_account_id] for every account,
# disambiguating duplicate names with the (unique, stable) txn-account id.
def account_targets(accounts)
  rows = accounts.map do |acct|
    ta = acct['primary_transaction_account'] || {}
    inst = (ta['institution'] || {})['title'] || 'Unknown'
    [folder_name(inst), folder_name(acct['title']), ta['id']]
  end

  name_counts = Hash.new(0)
  rows.each { |bank, name, _| name_counts[[bank, name]] += 1 }

  rows.map do |bank, name, id|
    name = "#{name}-#{id}" if name_counts[[bank, name]] > 1
    [bank, name, id]
  end
end

# Transaction-account ids that already have a pull shim somewhere under
# exports/, regardless of folder name — so renamed folders survive a re-sync.
def synced_ids(exports)
  Dir.glob(File.join(exports, '**', 'pull')).each_with_object({}) do |shim, ids|
    next unless File.file?(shim)

    id = File.read(shim)[/\baccount\s+(\d+)\b/, 1]
    ids[id.to_i] = shim if id
  end
end

def cmd_sync
  exports = File.expand_path('exports', repo_root)
  tool = File.expand_path(__FILE__)
  existing = synced_ids(exports)

  account_targets(fetch_accounts).each do |bank, name, id|
    next if id.nil?

    if (shim = existing[id])
      warn "skipped #{relative(shim, exports)} (account #{id} already synced)"
      next
    end

    dir = File.join(exports, bank, name)
    FileUtils.mkdir_p(dir)

    shim = File.join(dir, 'pull')
    File.write(shim, <<~SH)
      #!/usr/bin/env bash
      # Generated by pocketsmith-pull — Tally runs this during refresh.
      exec ruby "#{tool}" account #{id}
    SH
    File.chmod(0o755, shim)

    warn "synced #{bank}/#{name} (transaction account #{id})"
  end
end

def relative(path, base)
  path.sub(%r{\A#{Regexp.escape(base)}/}, '')
end

def repo_root
  # tools/ sits at the repo root next to exports/.
  File.expand_path('..', File.dirname(File.expand_path(__FILE__)))
end

LOG_FILE = 'pull.log'

# Determine the start_date for an incremental pull from the last log entry.
# Returns nil on first run (no log) so the full history is fetched.
def window_start
  return nil unless File.exist?(LOG_FILE)

  last = File.readlines(LOG_FILE).reject { |l| l.strip.empty? }.last
  return nil if last.nil?

  to = last.split("\t")[2]
  return nil if to.nil? || to == '-'

  (Date.parse(to) - OVERLAP_DAYS).to_s
rescue ArgumentError
  nil
end

def to_cents(value)
  ((value || 0).to_f * 100).round
end

def build_metadata(txn)
  meta = { 'pocketsmith_id' => txn['id'] }

  if (cat = txn['category'])
    meta['pocketsmith_category'] = cat['title']
    meta['pocketsmith_category_id'] = cat['id']
  end

  labels = txn['labels']
  meta['pocketsmith_labels'] = labels if labels.is_a?(Array) && !labels.empty?

  %w[note memo].each do |field|
    val = txn[field]
    meta[field] = val if val && !val.to_s.strip.empty?
  end

  original = txn['original_payee']
  meta['original_payee'] = original if original && original != txn['payee']

  meta
end

def cmd_account(id)
  abort 'usage: pocketsmith-pull account <transaction_account_id>' if id.nil?

  start = window_start
  finish = Date.today.to_s

  # PocketSmith requires start_date and end_date together (or neither). On the
  # first run (no log) we omit both to fetch the account's full history.
  url = "#{API_BASE}/transaction_accounts/#{id}/transactions?per_page=100"
  url += "&start_date=#{start}&end_date=#{finish}" if start

  txns = api_get_all(url)

  out = txns.map do |txn|
    {
      date: txn['date'],
      description: txn['payee'].to_s,
      amount_cents: to_cents(txn['amount']),
      balance_cents: to_cents(txn['closing_balance']),
      hash: "ps-#{txn['id']}",
      metadata: build_metadata(txn)
    }
  end

  puts JSON.generate(out)

  File.open(LOG_FILE, 'a') do |f|
    f.puts [Time.now.utc.iso8601, start || '-', finish, out.length].join("\t")
  end
end

case ARGV[0]
when 'sync'
  cmd_sync
when 'account'
  cmd_account(ARGV[1])
else
  warn 'usage: pocketsmith-pull {sync | account <transaction_account_id>}'
  exit 1
end
